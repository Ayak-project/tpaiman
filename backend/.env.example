# Example environment variables for backend
# Copy this file to `.env` at the project root or backend folder
# and replace the placeholder values with your own secrets.

# ---------------------------------------------------------------------
# Supabase credentials (required)
# ---------------------------------------------------------------------
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=<service-role-key>         # keep this secret!

# (optional) additional Supabase settings you may need:
# SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_JWT_SECRET=<jwt-secret>

# ---------------------------------------------------------------------
# Cloudinary credentials (required for file uploads)
# ---------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>
# alternatively you can use the URL format:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# ---------------------------------------------------------------------
# Other configuration
# ---------------------------------------------------------------------
# PORT=8000        # if you need to override the default port
# DEBUG=true       # custom flags your app might use
